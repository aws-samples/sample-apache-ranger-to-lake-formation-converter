<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Simple console pattern layout for test readability.
         logback-test.xml takes precedence over logback.xml during tests,
         so tests get human-readable output instead of JSON. -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} %-5level [%logger] - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
